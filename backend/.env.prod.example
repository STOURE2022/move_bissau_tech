# ============================================================
# MoveBissau — Variables d'environnement PRODUCTION (GCP)
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# === Django ===
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=GENEREZ_UNE_CLE_SECRETE_AVEC_python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=api.movebissau.com,admin.movebissau.com,app.movebissau.com

# === Base de données (Docker interne) ===
DB_NAME=movebissau
DB_USER=movebissau
DB_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT
DB_HOST=db
DB_PORT=5432

# === Redis (Docker interne) ===
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === CORS ===
CORS_ALLOWED_ORIGINS=https://app.movebissau.com,https://admin.movebissau.com

# === Chiffrement ===
ENCRYPTION_KEY=GENEREZ_32_CARACTERES_ALEATOIRES

# === Stockage fichiers ===
USE_S3=False
# Pour Google Cloud Storage, activez USE_S3=True et configurez :
# AWS_ACCESS_KEY_ID=votre_cle
# AWS_SECRET_ACCESS_KEY=votre_secret
# AWS_STORAGE_BUCKET_NAME=movebissau-media
# AWS_S3_ENDPOINT_URL=https://storage.googleapis.com

# === Sentry (monitoring erreurs) ===
# SENTRY_DSN=https://xxx@sentry.io/yyy

# === Domaines ===
API_DOMAIN=api.movebissau.com
ADMIN_DOMAIN=admin.movebissau.com
APP_DOMAIN=app.movebissau.com
